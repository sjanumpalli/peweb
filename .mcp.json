{
  "mcpServers": {
    "stitch": {
      "command": "npx",
      "args": ["-y", "@_davideast/stitch-mcp@latest", "proxy"],
      "env": {
        "STITCH_API_KEY": ""
      }
    },
    "nano-banana": {
      "command": "npx",
      "args": ["-y", "nano-banana-mcp@latest"],
      "env": {
        "GEMINI_API_KEY": ""
      }
    },
    "magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": ""
      }
    }
  }
}
